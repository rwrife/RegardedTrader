# --- OpenAI (or compatible) ---
OPENAI_API_KEY=
# Most users won't set keys here anymore. Provider keys live in the local config
# file (`~/.regardedtrader/config.json`) and are managed via `regard config`
# (CLI) or the web Settings page. The legacy variables below still work as a
# bootstrap when the config file is empty:
OPENAI_API_KEY_LEGACY=
OPENAI_MODEL=gpt-4o-mini

# --- Server ---
# Local-only. Do not change unless you know what you're doing.
HOST=127.0.0.1
PORT=4317

# --- Optional market data providers ---
# Yahoo Finance is used by default and needs no key.
POLYGON_API_KEY=
ALPHA_VANTAGE_API_KEY=

# --- Storage ---
# Defaults to ~/.regardedtrader/
REGARDEDTRADER_HOME=

# --- Safety ---
# Must be "true" to enable any simulated execution code paths.
ALLOW_PAPER_TRADING=false
